# ---- Telemetry (Forza "Data Out" UDP stream) ----
# Bind address the listener reads from. Match the IP/port you set in-game.
# In-game set "Data Out IP Address" to 127.0.0.1 and "Data Out Port" to UDP_PORT.
UDP_HOST=0.0.0.0
UDP_PORT=9999

# ---- File logging ----
# Where session CSV/JSONL telemetry logs are written.
LOG_DIR=./logs
# Throttle: log every Nth incoming packet (telemetry is ~60Hz; 1 = every packet).
LOG_STRIDE=5
LOG_FORMAT=csv            # csv | jsonl | both

# ---- Rolling buffer (in-memory window shown in the UI / sent to the LLM) ----
BUFFER_FRAMES=600         # ~10s of data at 60Hz

# ---- LLM provider selection ----
# One of: openai | anthropic | deepseek
LLM_PROVIDER=openai

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=          # leave blank for the default OpenAI endpoint

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=       # leave blank for the default Anthropic endpoint

# ---- DeepSeek (OpenAI-compatible) ----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Server ----
WEB_HOST=127.0.0.1
WEB_PORT=8000